    "@capacitor/core": "^8.1.0",
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.9",
    "@types/pg": "^8.16.0",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.170.0",
    "@types/unzip-stream": "^0.3.4",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
