    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.2",
    "sass": "^1.97.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.17"
  },
  "homepage": "https://tidecommander.com/",
  "keywords": [
    "ai",
    "developer-tools",
    "codex",
    "orchestrator",
    "vibe-coding",
    "claude-code",
    "tide-commander"
  ],
  "license": "MIT"
}
