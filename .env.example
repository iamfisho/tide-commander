# Tide Commander Environment Configuration
# Copy this file to .env and adjust values as needed.

# Backend server port (default: 6200)
PORT=6200

# Frontend dev server port (default: 5173)
VITE_PORT=5173

# Set to any value to listen on all network interfaces (0.0.0.0) instead of localhost only
# LISTEN_ALL_INTERFACES=1

# Security token for authenticating WebSocket and HTTP connections
# If set, clients must provide this token to connect
# Generate a secure random token: openssl rand -hex 32
# AUTH_TOKEN=your-secret-token-here

# Enable HTTPS/WSS server mode (set to 1)
# HTTPS=1

# TLS certificate files (required when HTTPS=1 unless defaults exist at ~/.tide-commander/certs/)
# TLS_KEY_PATH=~/.tide-commander/certs/localhost-key.pem
# TLS_CERT_PATH=~/.tide-commander/certs/localhost.pem

# Override the Codex binary path. Point to the native binary to avoid the
# Node.js wrapper and prevent session loss when Tide Commander restarts.
# Example: CODEX_BINARY=~/.nvm/versions/node/v20.18.2/lib/node_modules/@openai/codex/node_modules/@openai/codex-linux-x64/vendor/x86_64-unknown-linux-musl/codex/codex
# CODEX_BINARY=

# Enable HTTPS for the Vite dev server (set to 1)
# DEV_HTTPS=1

# TLS certificate files for Vite dev server when DEV_HTTPS=1
# DEV_TLS_KEY_PATH=~/.tide-commander/certs/localhost-key.pem
# DEV_TLS_CERT_PATH=~/.tide-commander/certs/localhost.pem
